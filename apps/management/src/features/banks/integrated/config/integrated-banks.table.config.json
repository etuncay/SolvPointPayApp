{
  "title": "Entegre Bankalar",
  "rowKey": "id",
  "pagination": {
    "defaultPageSize": 20,
    "pageSizeOptions": [10, 20, 50, 100]
  },
  "search": {
    "placeholder": "Banka adı veya servis ara…",
    "keys": ["bankName", "service"]
  },
  "hideColumnFilters": true,
  "advancedFilters": [
    {
      "key": "status",
      "label": "Statü",
      "type": "select",
      "span": 3,
      "options": [
        { "label": "Tümü", "value": "any" },
        { "label": "Aktif", "value": "Active" },
        { "label": "Pasif", "value": "Inactive" }
      ]
    }
  ],
  "toolbar": {
    "new": { "label": "Banka Ekle" },
    "export": {}
  },
  "columns": [
    { "key": "bankName", "title": "Banka", "dataIndex": "bankName", "sortable": true, "minWidth": 180 },
    { "key": "service", "title": "Servis", "dataIndex": "service", "sortable": true, "mono": true, "width": 140 },
    { "key": "eftStartTime", "title": "EFT Baş", "dataIndex": "eftStartTime", "sortable": true, "mono": true, "width": 95, "render": "renderOptional" },
    { "key": "eftEndTime", "title": "EFT Bitiş", "dataIndex": "eftEndTime", "sortable": true, "mono": true, "width": 95, "render": "renderOptional" },
    { "key": "isDefaultEft", "title": "Vars. EFT", "dataIndex": "isDefaultEft", "sortable": true, "align": "center", "width": 85, "render": "renderBool" },
    { "key": "hasIbanCheck", "title": "IBAN", "dataIndex": "hasIbanCheck", "sortable": true, "align": "center", "width": 70, "render": "renderBool" },
    { "key": "isDefaultIbanCheck", "title": "Vars. IBAN", "dataIndex": "isDefaultIbanCheck", "sortable": true, "align": "center", "width": 95, "render": "renderBool" },
    { "key": "hasFast", "title": "FAST", "dataIndex": "hasFast", "sortable": true, "align": "center", "width": 70, "render": "renderBool" },
    { "key": "isDefaultFast", "title": "Vars. FAST", "dataIndex": "isDefaultFast", "sortable": true, "align": "center", "width": 95, "render": "renderBool" },
    { "key": "reconciliationFeeApplied", "title": "Mut. Ücret", "dataIndex": "reconciliationFeeApplied", "sortable": true, "align": "center", "width": 95, "render": "renderBool" },
    { "key": "lastSuccessCallAt", "title": "Son Çağrı", "dataIndex": "lastSuccessCallAt", "sortable": true, "mono": true, "width": 150, "render": "renderLastCall" },
    { "key": "status", "title": "Statü", "dataIndex": "status", "sortable": true, "width": 110, "render": "renderStatus" },
    { "key": "actions", "title": "", "dataIndex": "id", "width": 96, "render": "renderActions" }
  ]
}

