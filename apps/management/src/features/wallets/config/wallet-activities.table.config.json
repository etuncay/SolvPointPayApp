{
  "title": "Cüzdan Hareketleri",
  "rowKey": "id",
  "pagination": {
    "defaultPageSize": 20,
    "pageSizeOptions": [10, 20, 50, 100]
  },
  "search": {
    "placeholder": "İşlem no, referans, karşı taraf ara…",
    "keys": ["transactionNo", "referenceNo", "counterpartyName", "counterpartyAccount"]
  },
  "hideColumnFilters": true,
  "toolbar": { "export": {} },
  "chips": {
    "key": "direction",
    "label": "Yön",
    "options": [
      { "label": "Tümü", "value": "all" },
      { "label": "Giriş", "value": "Inflow" },
      { "label": "Çıkış", "value": "Outflow" }
    ]
  },
  "advancedFilters": [
    {
      "key": "status",
      "label": "Durum",
      "type": "select",
      "span": 3,
      "options": [
        { "label": "Tümü", "value": "all" },
        { "label": "Completed", "value": "Completed" },
        { "label": "Pending", "value": "Pending" },
        { "label": "OnHold", "value": "OnHold" },
        { "label": "Sent", "value": "Sent" },
        { "label": "ErrorComplete", "value": "ErrorComplete" },
        { "label": "Canceled", "value": "Canceled" }
      ]
    },
    {
      "key": "currency",
      "label": "PB",
      "type": "select",
      "span": 3,
      "options": [
        { "label": "Tümü", "value": "all" },
        { "label": "TRY", "value": "TRY" },
        { "label": "USD", "value": "USD" },
        { "label": "EUR", "value": "EUR" },
        { "label": "GBP", "value": "GBP" }
      ]
    },
    {
      "key": "transactionType",
      "label": "İşlem Tipi",
      "type": "select",
      "span": 4,
      "options": [
        { "label": "Tümü", "value": "all" },
        { "label": "WalletTopUp", "value": "WalletTopUp" },
        { "label": "WalletToPerson", "value": "WalletToPerson" },
        { "label": "WalletToBankAccount", "value": "WalletToBankAccount" },
        { "label": "InternationalTransfer", "value": "InternationalTransfer" },
        { "label": "WalletWithdrawal", "value": "WalletWithdrawal" },
        { "label": "WalletDeposit", "value": "WalletDeposit" },
        { "label": "InternalTransfer", "value": "InternalTransfer" }
      ]
    },
    { "key": "createdFrom", "label": "Tarih (Baş)", "type": "date", "span": 3 },
    { "key": "createdTo", "label": "Tarih (Bitiş)", "type": "date", "span": 3 }
  ],
  "columns": [
    { "key": "transactionNo", "title": "İşlem No", "dataIndex": "transactionNo", "sortable": true, "width": 130, "render": "renderMono" },
    { "key": "createdAt", "title": "Tarih", "dataIndex": "createdAt", "sortable": true, "width": 140, "render": "renderSoftMono" },
    { "key": "direction", "title": "Yön", "dataIndex": "direction", "sortable": true, "width": 110, "render": "renderDirection" },
    { "key": "counterpartyNo", "title": "Karşı No", "dataIndex": "counterpartyNo", "sortable": true, "width": 120, "render": "renderMonoOrDash" },
    { "key": "counterpartyName", "title": "Karşı Ad", "dataIndex": "counterpartyName", "sortable": true, "minWidth": 180 },
    { "key": "counterpartyAccount", "title": "Karşı Hesap", "dataIndex": "counterpartyAccount", "sortable": true, "width": 170, "render": "renderMono" },
    { "key": "referenceNo", "title": "Referans", "dataIndex": "referenceNo", "sortable": true, "width": 130, "render": "renderMono" },
    { "key": "transactionType", "title": "Tip", "dataIndex": "transactionType", "sortable": true, "width": 160, "render": "renderType" },
    { "key": "currency", "title": "PB", "dataIndex": "currency", "sortable": true, "width": 90, "render": "renderMono" },
    { "key": "amount", "title": "Tutar", "dataIndex": "amount", "sortable": true, "width": 130, "render": "renderAmount" },
    { "key": "postBalance", "title": "Son Bakiye", "dataIndex": "postBalance", "sortable": true, "width": 130, "render": "renderPostBalance" },
    { "key": "status", "title": "Durum", "dataIndex": "status", "sortable": true, "width": 120, "render": "renderStatus" }
  ]
}
