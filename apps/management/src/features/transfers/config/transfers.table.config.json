  "columns": [
    { "key": "transactionNo", "title": "İşlem No", "dataIndex": "transactionNo", "sortable": true, "width": 140, "render": "renderMono" },
    { "key": "createdAt", "title": "Tarih", "dataIndex": "createdAt", "sortable": true, "width": 140, "render": "renderSoftMono" },
    { "key": "senderCustomerNo", "title": "Gönderen Müşteri", "dataIndex": "senderCustomerNo", "sortable": true, "width": 130, "render": "renderMonoOrDash" },
    { "key": "senderWalletNo", "title": "Gönderen Cüzdan", "dataIndex": "senderWalletNo", "sortable": true, "width": 140, "render": "renderMonoOrDash" },
    { "key": "senderName", "title": "Gönderen Ad", "dataIndex": "senderName", "minWidth": 170 },
    { "key": "senderAgentNo", "title": "Gönderen Temsilci No", "dataIndex": "senderAgentNo", "sortable": true, "width": 150, "render": "renderMonoOrDash" },
    { "key": "receiverCustomerNo", "title": "Alıcı Müşteri", "dataIndex": "receiverCustomerNo", "sortable": true, "width": 130, "render": "renderMonoOrDash" },
    { "key": "receiverWalletNo", "title": "Alıcı Cüzdan", "dataIndex": "receiverWalletNo", "sortable": true, "width": 140, "render": "renderMonoOrDash" },
    { "key": "receiverName", "title": "Alıcı Ad", "dataIndex": "receiverName", "minWidth": 170 },
    { "key": "receiverAgentNo", "title": "Alıcı Temsilci No", "dataIndex": "receiverAgentNo", "sortable": true, "width": 150, "render": "renderMonoOrDash" },
    { "key": "iban", "title": "IBAN", "dataIndex": "iban", "width": 170, "render": "renderMonoOrDash" },
    { "key": "transactionType", "title": "İşlem Tipi", "dataIndex": "transactionType", "sortable": true, "width": 160, "render": "renderTxType" },
    { "key": "sourceCurrency", "title": "PB", "dataIndex": "sourceCurrency", "sortable": true, "width": 90, "render": "renderMono" },
    { "key": "principalAmount", "title": "Tutar", "dataIndex": "principalAmount", "sortable": true, "width": 130, "render": "renderAmount" },
    { "key": "status", "title": "Durum", "dataIndex": "status", "sortable": true, "width": 130, "render": "renderStatus" }
