  },
  "hideColumnFilters": true,
  "chips": {
    "key": "status",
    "label": "Durum",
    "options": [
      { "label": "Tümü", "value": "all" },
      { "label": "Pending", "value": "Pending" },
      { "label": "OnHold", "value": "OnHold" },
      { "label": "Completed", "value": "Completed" },
      { "label": "Canceled", "value": "Canceled" }
    ]
  },
  "advancedFilters": [
    { "key": "sourceCurrency", "label": "Para Birimi", "type": "select", "span": 3, "options": [{ "label": "Tümü", "value": "all" }, { "label": "TRY", "value": "TRY" }, { "label": "USD", "value": "USD" }, { "label": "EUR", "value": "EUR" }, { "label": "GBP", "value": "GBP" }] },
    { "key": "transactionType", "label": "İşlem Tipi", "type": "select", "span": 4, "options": [{ "label": "Tümü", "value": "all" }, { "label": "WalletTopUp", "value": "WalletTopUp" }, { "label": "WalletToPerson", "value": "WalletToPerson" }, { "label": "WalletToBankAccount", "value": "WalletToBankAccount" }, { "label": "InternationalTransfer", "value": "InternationalTransfer" }, { "label": "WalletWithdrawal", "value": "WalletWithdrawal" }, { "label": "WalletDeposit", "value": "WalletDeposit" }, { "label": "InternalTransfer", "value": "InternalTransfer" }] },
    { "key": "from", "label": "Tarih (Baş)", "type": "date", "span": 3 },
    { "key": "to", "label": "Tarih (Bitiş)", "type": "date", "span": 3 }
