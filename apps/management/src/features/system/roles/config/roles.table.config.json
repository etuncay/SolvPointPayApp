    { "key": "status", "title": "Status", "dataIndex": "status", "sortable": true, "width": 120, "render": "renderStatus" },
    { "key": "createdAt", "title": "Oluşturma", "dataIndex": "createdAt", "sortable": true, "width": 130, "render": "renderCreatedAt" },
    { "key": "updatedAt", "title": "Son Güncelleme", "dataIndex": "updatedAt", "sortable": true, "width": 140, "render": "renderUpdatedAt" }
