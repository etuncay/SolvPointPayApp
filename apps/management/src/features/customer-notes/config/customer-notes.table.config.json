{
  "title": "Müşteri Notları",
  "rowKey": "id",
  "pagination": {
    "defaultPageSize": 20,
    "pageSizeOptions": [10, 20, 50, 100]
  },
  "search": {
    "placeholder": "Müşteri no veya metin ara…",
    "keys": ["customerNo", "noteText"]
  },
  "hideColumnFilters": true,
  "advancedFilters": [
    {
      "key": "target",
      "label": "Bilgilendirilen",
      "type": "select",
      "span": 3,
      "options": [
        { "label": "Bireysel Müşteri", "value": "IndividualCustomer" },
        { "label": "Tüzel Müşteri", "value": "CorporateCustomer" },
        { "label": "Temsilci", "value": "Agent" }
      ]
    },
    {
      "key": "priority",
      "label": "Öncelik",
      "type": "select",
      "span": 3,
      "options": [
        { "label": "Düşük", "value": "Low" },
        { "label": "Orta", "value": "Medium" },
        { "label": "Yüksek", "value": "High" },
        { "label": "Kritik", "value": "Critical" }
      ]
    }
  ],
  "toolbar": {
    "new": { "label": "Yeni Not" }
  },
  "columns": [
    {
      "key": "customerNo",
      "title": "Müşteri No",
      "dataIndex": "customerNo",
      "sortable": true,
      "mono": true,
      "width": 130
    },
    {
      "key": "noteText",
      "title": "Bilgilendirme Metni",
      "dataIndex": "noteText",
      "minWidth": 280
    },
    {
      "key": "target",
      "title": "Bilgilendirilen",
      "dataIndex": "targetEntityType",
      "sortable": true,
      "width": 150,
      "render": "renderTarget"
    },
    {
      "key": "priority",
      "title": "Öncelik",
      "dataIndex": "priorityLevel",
      "sortable": true,
      "width": 120,
      "render": "renderPriority"
    },
    {
      "key": "displayLimit",
      "title": "Gösterim Limiti",
      "dataIndex": "displayLimit",
      "sortable": true,
      "align": "center",
      "width": 120,
      "render": "renderDisplayLimit"
    },
    {
      "key": "displayCount",
      "title": "Gösterim Adedi",
      "dataIndex": "displayCount",
      "sortable": true,
      "align": "center",
      "mono": true,
      "width": 120,
      "render": "renderDisplayCount"
    },
    {
      "key": "endDate",
      "title": "Bitiş Tarihi",
      "dataIndex": "endDate",
      "sortable": true,
      "mono": true,
      "width": 130,
      "render": "renderEndDate"
    },
    {
      "key": "actions",
      "title": "",
      "dataIndex": "id",
      "width": 72,
      "render": "renderActions"
    }
  ]
}
