{
  "title": "Müşteri Listesi",
  "rowKey": "id",
  "pagination": {
    "defaultPageSize": 15,
    "pageSizeOptions": [10, 15, 25, 50, 100]
  },
  "search": {
    "placeholder": "Müşteri no, ad, e-posta, telefon ara…",
    "keys": ["id", "name", "email", "phone"]
  },
  "hideColumnFilters": true,
  "advancedFilters": [
    {
      "key": "type",
      "label": "Müşteri tipi",
      "type": "select",
      "span": 3,
      "options": [
        { "label": "Bireysel", "value": "individual" },
        { "label": "Tüzel", "value": "corporate" }
      ]
    },
    {
      "key": "city",
      "label": "Şehir",
      "type": "text",
      "placeholder": "Şehir ara…",
      "span": 3
    },
    {
      "key": "createdFrom",
      "label": "Oluşturma (başlangıç)",
      "type": "date",
      "span": 3
    },
    {
      "key": "createdTo",
      "label": "Oluşturma (bitiş)",
      "type": "date",
      "span": 3
    }
  ],
  "tabs": [
    { "key": "all", "title": "Tümü", "filters": {}, "countKey": "allCount" },
    { "key": "active", "title": "Aktif", "filters": { "status": "Active" }, "countKey": "activeCount" },
    { "key": "passive", "title": "Pasif", "filters": { "status": "Passive" }, "countKey": "passiveCount" },
    { "key": "blocked", "title": "Bloke", "filters": { "status": "Blocked" }, "countKey": "blockedCount" },
    { "key": "pending", "title": "Beklemede", "filters": { "status": "Pending" }, "countKey": "pendingCount" }
  ],
  "toolbar": {
    "export": { "label": "Dışa Aktar" },
    "new": { "label": "Yeni Müşteri" }
  },
  "selectable": true,
  "columnToggle": true,
  "bulkActions": [
    { "key": "bulkExport", "label": "Seçilenleri dışa aktar", "icon": "download" },
    {
      "key": "bulkDelete",
      "label": "Seçilenleri sil",
      "variant": "danger",
      "confirm": "Seçili kayıtları silmek istediğinize emin misiniz?"
    }
  ],
  "columns": [
    {
      "key": "id",
      "title": "Müşteri No",
      "dataIndex": "id",
      "sortable": true,
      "mono": true,
      "width": 100
    },
    {
      "key": "name",
      "title": "Ad Soyad / Unvan",
      "dataIndex": "name",
      "sortable": true,
      "minWidth": 180
    },
    {
      "key": "type",
      "title": "Tip",
      "dataIndex": "type",
      "width": 100
    },
    {
      "key": "status",
      "title": "Durum",
      "dataIndex": "status",
      "width": 100,
      "format": "status",
      "sortable": true
    },
    {
      "key": "city",
      "title": "Şehir",
      "dataIndex": "city",
      "width": 120,
      "sortable": true
    },
    {
      "key": "balance",
      "title": "Bakiye (TRY)",
      "dataIndex": "balance",
      "width": 130,
      "align": "right",
      "format": "currency",
      "sortable": true,
      "mono": true
    },
    {
      "key": "riskScore",
      "title": "Risk",
      "dataIndex": "riskScore",
      "width": 70,
      "align": "center",
      "sortable": true
    },
    {
      "key": "createdAt",
      "title": "Kayıt Tarihi",
      "dataIndex": "createdAt",
      "width": 140,
      "format": "date",
      "sortable": true
    }
  ]
}
