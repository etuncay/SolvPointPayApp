{
  "title": "İşlem Hareketleri",
  "rowKey": "id",
  "hideTitleBar": true,
  "pagination": {
    "defaultPageSize": 20,
    "pageSizeOptions": [20, 50, 100]
  },
  "search": {
    "placeholder": "İşlem no, referans, gönderen, alıcı, IBAN…",
    "keys": ["transactionNo", "referenceNo", "senderName", "receiverName", "iban"]
  },
  "hideColumnFilters": true,
  "tabs": [
    { "key": "all", "title": "Tümü", "countKey": "countAll" },
