    { "key": "Pending", "title": "Bekliyor", "filters": { "status": "Pending" }, "countKey": "countPending" },
    { "key": "Sent", "title": "Gönderildi", "filters": { "status": "Sent" }, "countKey": "countSent" },
    { "key": "OnHold", "title": "Beklemede", "filters": { "status": "OnHold" }, "countKey": "countOnHold" },
    { "key": "Rejected", "title": "Reddedildi", "filters": { "status": "Rejected" }, "countKey": "countRejected" }
