{
  "name": "@epay/domain",
  "version": "0.0.0",
  "private": true,
  "description": "Ortak domain sözlüğü (types, enums, referans sabitleri) — UI ve persistence bağımsız",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./transaction": "./src/transaction/index.ts",
    "./customer": "./src/customer/index.ts",
