    "./transfer": "./src/transfer/index.ts",
    "./reference": "./src/reference/index.ts"
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@epay/tsconfig": "workspace:*",
    "typescript": "^5.8.3"
  }
}
